# ── Postgres ──────────────────────────────────────────────
DB_HOST=db
DB_USERNAME=lumen
DB_PASSWORD=lumen_dev_password
DB_NAME=lumen_development

# ── Rails ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=replace_with_64_hex_chars

# ── JWT ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_hex_chars
JWT_EXPIRY_HOURS=0.25

# ── S3 / LocalStack (local dev) ───────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=eu-west-1
S3_BUCKET_NAME=lumen-media
S3_ENDPOINT=http://localstack:4566
S3_FORCE_PATH_STYLE=true
# Host-side URL for presigned links returned to the browser/app
S3_PUBLIC_ENDPOINT=http://localhost:4567

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
