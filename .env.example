# ── Postgres ──────────────────────────────────────────────
DB_HOST=db
DB_USERNAME=lumen
DB_PASSWORD=lumen_dev_password
DB_NAME=lumen_development

# ── Rails ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=replace_with_64_hex_chars

# ── JWT ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_hex_chars
JWT_EXPIRY_HOURS=0.25

# ── S3 / LocalStack (local dev) ───────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=eu-west-1
S3_BUCKET_NAME=lumen-media
S3_ENDPOINT=http://localstack:4566
S3_FORCE_PATH_STYLE=true
# Host-side URL for presigned links returned to the browser/app
S3_PUBLIC_ENDPOINT=http://localhost:4567

# ── S3 / Cloudflare R2 (production — set via `fly secrets set`) ───
# 1. Create a bucket in the Cloudflare dashboard (R2 → Create bucket)
# 2. Create an API token (R2 → Manage API Tokens → Object Read & Write)
# 3. Find your Account ID on the R2 overview page
#
# AWS_ACCESS_KEY_ID=<r2-access-key-id>
# AWS_SECRET_ACCESS_KEY=<r2-secret-access-key>
# AWS_REGION=auto
# S3_BUCKET_NAME=lumen-media
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
# (S3_PUBLIC_ENDPOINT is not needed — R2 presigned URLs are publicly reachable)

# ── SSO ───────────────────────────────────────────────────
# Google: Web OAuth 2.0 client ID from console.cloud.google.com
# → APIs & Services → Credentials → Create OAuth client ID (Web application)
GOOGLE_CLIENT_ID=

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
